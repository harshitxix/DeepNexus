# Backend Environment Variables
# Copy this to .env in the backend directory for production

# API Settings
DEBUG=false
ENVIRONMENT=production

# CORS Settings
CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Database (if needed)
DATABASE_URL=postgresql://user:password@db-host:5432/deepnexus

# Server Settings
API_TITLE=DeepNexus API
API_VERSION=1.0.0

# Logging
LOG_LEVEL=info

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production

# NVIDIA API key used by Study Assistant
NVIDIA_API_KEY=your-nvidia-api-key-here

# Optional: Third-party services
OPENCV_MAX_WORKERS=4
