# Backend Environment Variables for Production
# Used by Render deployment
# Add these as Render Environment Variables in dashboard

# Debug & Environment
DEBUG=false
ENVIRONMENT=production
PYTHONUNBUFFERED=true
PYTHONPATH=/backend

# CORS Configuration - SET TO YOUR VERCEL FRONTEND URL
# Format: https://your-domain.vercel.app
# Add multiple URLs separated by commas for multiple environments
CORS_ORIGINS=https://your-vercel-frontend-url.vercel.app

# Server Settings
API_TITLE=DeepNexus API
API_VERSION=1.0.0

# Logging (options: debug, info, warning, error)
LOG_LEVEL=info

# External API Keys (if using AI features)
# NVIDIA API Key for Study Mode and Data Engine features
NVIDIA_API_KEY=your-nvidia-api-key-here

# Database (optional - leave empty if not using)
# DATABASE_URL=postgresql://user:password@host:5432/deepnexus

# Notes:
# - For Render free tier: Services spin down after 15 min inactivity
# - For production: Upgrade to Render Starter ($7/month) or higher
# - Never commit actual .env file with real secrets to git
# - Use Render dashboard Environment Variables UI instead

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production

# NVIDIA API key used by Study Assistant
NVIDIA_API_KEY=your-nvidia-api-key-here

# Optional: Third-party services
OPENCV_MAX_WORKERS=4
