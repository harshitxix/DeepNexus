{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install",
  "env": {
    "VITE_API_BASE": {
      "default": "https://deepnexus-api.onrender.com/api"
    }
  },
  "functions": {
    "api/**/*.js": {
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "${VITE_API_BASE}/$1"
    }
  ]
}
